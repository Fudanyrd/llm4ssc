 author = {Katina Michael and Rebecca Herold and George Roussos},
 doi = {https://doi.org/10.1016/j.cose.2025.104804},
 issn = {0167-4048},
 journal = {Computers \& Security},
 pages = {104804},
 title = {Security and regulation: Cybersecurity, privacy, and trust- protecting information and ensuring responsible technology use},
 url = {https://www.sciencedirect.com/science/article/pii/S0167404825004936},
 volume = {162},
 year = {2026}
