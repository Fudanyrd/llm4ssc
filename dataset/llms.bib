@article{csllm,
title = {CSLLM: Code-Specific Large Language Models--A Survey},
journal = {Expert Systems with Applications},
volume = {308},
pages = {130991},
year = {2026},
issn = {0957-4174},
doi = {https://doi.org/10.1016/j.eswa.2025.130991},
url = {https://www.sciencedirect.com/science/article/pii/S0957417425046068},
author = {Jayesh Umre and Ashish Singh Parihar and Atul Gupta},
keywords = {Large language models,, Transformer models,, Automated code generation,, Software engineering,, AI In programming},
abstract = {Large Language Models (LLMs) have fundamentally changed code engineering by automating code-related tasks, including code generation, completion, debugging, and optimization. General-purpose LLMs sometimes struggle with code-specific challenges, including syntax errors, suboptimal code efficiency, and security vulnerabilities, notwithstanding their success. Using specialized datasets, domain-adaptive training, and focused fine-tuning techniques, CSLLMs (Code-Specific Large Language Models) have emerged to solve these problems. Synthesizing present research on CSLLMs, this literature review investigates their architectures, training paradigms, motivating strategies, fine-tuning techniques, benchmark datasets, and evaluation approaches. To highlight their strengths, constraints, and useful applications, eminent models including Codex, CodeT5, StarCoder, and DeepSeekCoder are arranged and comparatively studied. Driven by methods including identifier-aware pretraining, retrieval-augmented learning, and execution-based evaluation, the results show that CSLLMs routinely outperform general-purpose models in code accuracy, syntactic correctness, and execution reliability. Still, there are important obstacles, including ethical issues in code generation, computational complexity, and dataset biases. Our study emphasizes exciting research directions, supports hybrid architectures, strong execution-based evaluations, and ethical frameworks, and guides next developments in AI-assisted programming for both industry and academia.}
}

@inbook{nlp,
author="Chowdhary, K. R.",
title="Natural Language Processing",
bookTitle="Fundamentals of Artificial Intelligence",
year="2020",
publisher="Springer India",
address="New Delhi",
pages="603--649",
abstract="The abundant volume of natural language text in the connected world, though having a large content of knowledge, but it is becoming increasingly difficult to disseminate it by a human to discover the knowledge/wisdom in it, specifically within any given time limits. The automated NLP is aimed to do this job effectively and with accuracy, like a human does it (for a limited of amount text). This chapter presents the challenges of NLP, progress so far made in this field, NLP applications, components of NLP, and grammar of English language---the way machine requires it. In addition, covers the specific areas like probabilistic parsing, ambiguities and their resolution, information extraction, discourse analysis, NL question-answering, commonsense interfaces, commonsense thinking and reasoning, causal-diversity, and various tools for NLP. Finally, the chapter summary, and a set of relevant exercises are presented.",
isbn="978-81-322-3972-7",
doi="10.1007/978-81-322-3972-7_19",
url="https://doi.org/10.1007/978-81-322-3972-7_19"
}




