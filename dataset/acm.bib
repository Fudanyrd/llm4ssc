@inproceedings{10.1145/3512353.3512377,
author = {Zhang, Xin and Lu, Qiuchen and Ma, Yanbo},
title = {Research on Information Asymmetric Incentive Contract Design of Drug Recovery Reverse Supply Chain under Government Supervision},
year = {2022},
isbn = {9781450395571},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3512353.3512377},
doi = {10.1145/3512353.3512377},
abstract = {Currently, Chinese residents of expired drugs and other inferior drugs treatment is not scientific because of the lack of environmental awareness and public safety awareness. Meanwhile, the participants in the drug recycling market are not in the cooperation of establishing a reasonable recycling mechanism. This work uses principal-agent theory and display principle to establish a Stackelberg game model with a medical institution and a recycler as participants under the supervision of the government. Then, we further explore the optimal incentive contract in the recycling reverse supply chain, analyse the impact of information asymmetry, and consider the public welfare factors of the medical institution and customers in there. Studies shows that transactions occur when both the recycler and the medical institution have their retained utility at least. When the cost declared by the recycler is within the acceptable range of the medical institution, the medical institution would encourage the recycler to participate in the recovery and expose its real recovery cost by designing two pricing contracts. Government subsidies will rise as reporting costs rise, and it will be minimized when the medical institution and the recycler take their retained utility. The government should reduce the overall reserve profit of the supply chain through the guidance of public consciousness and the incentive at the policy level, and save the expenditure while ensuring the recovery effect of the reverse supply chain.},
booktitle = {Proceedings of the 2022 4th Asia Pacific Information Technology Conference},
pages = {160–168},
numpages = {9},
keywords = {Reverse supply chain, government subsidies, incentive contract design, information asymmetry},
location = {Virtual Event, Thailand},
series = {APIT '22}
}

@article{10.3233/JIFS-189532,
author = {Lu, Shaoqin},
title = {Enterprise supply chain risk assessment based on improved neural network algorithm and machine learning},
year = {2021},
issue_date = {2021},
publisher = {IOS Press},
address = {NLD},
volume = {40},
number = {4},
issn = {1064-1246},
url = {https://doi.org/10.3233/JIFS-189532},
doi = {10.3233/JIFS-189532},
abstract = {It is of practical significance to study the decision-making subject in the supply chain under the influence of risk aversion to make a decision and make the supply chain compete in an orderly market environment. In order to improve the effect of enterprise supply chain risk assessment, this paper improves the traditional neural network algorithm, combines machine learning methods and supply chain risk assessment time requirements to set system function modules, and builds the overall system structure. Considering the multiple relationship attributes of supply chain risk knowledge, this paper uses a multi-element semantic network to represent the network structure of supply chain risk knowledge, and proposes a multi-level inventory control modelThis is based on the inventory of the coordination center and other retailers’ procurement/relocation strategy models. After building the model, this paper designs a simulation test to verify and analyze the model performance. The research results show that the model proposed in this paper has a certain effect.},
journal = {J. Intell. Fuzzy Syst.},
month = jan,
pages = {7013–7024},
numpages = {12},
keywords = {Improved algorithm, neural network, machine learning, enterprise supply chain, risk assessment}
}

@article{10.1155/2021/9981019,
author = {Huang, Xiaohan and Sun, Jihong and Zhao, Xiaoyun},
editor = {Baogui Xin},
title = {Credit Risk Assessment of Supply Chain Financing with a Grey Correlation Model: An Empirical Study on China’s Home Appliance Industry},
year = {2021},
issue_date = {2021},
publisher = {John Wiley \&amp; Sons, Inc.},
address = {USA},
volume = {2021},
issn = {1076-2787},
url = {https://doi.org/10.1155/2021/9981019},
doi = {10.1155/2021/9981019},
abstract = {Supply chain finance (SCF) plays an increasingly important role in global enterprise competition. The credit risk accompanying SCF has attracted the attention of the government, enterprises, and academia. However, with the absence of data and inaccurate information, traditional risk assessment methods are frequently failed to assess the credit risk in SCF, especially for small- and medium-sized enterprises (SMEs). In this study, a grey correlation model is introduced and applied to the SCF risk assessment process for 15 firms in the Chinese home appliance industry with 15 performance indicators that represent profitability, solvency, operational capability, and development capability. The empirical study displays the operability and effectiveness of the grey correlation model, which is superior to traditional methods in the supply chain financial risk assessment.},
journal = {Complex.},
month = jan,
numpages = {12}
}

@article{10.1007/s00521-020-05044-w,
author = {Bo, Yang and Meifang, Yang},
title = {Construction of the knowledge service model of a port supply chain enterprise in a big data environment},
year = {2021},
issue_date = {Mar 2021},
publisher = {Springer-Verlag},
address = {Berlin, Heidelberg},
volume = {33},
number = {5},
issn = {0941-0643},
url = {https://doi.org/10.1007/s00521-020-05044-w},
doi = {10.1007/s00521-020-05044-w},
abstract = {In the context of the rapid development of big data and artificial intelligence, knowledge service theory and big data technology are applied to build a smart port supply chain knowledge service model. This model provides a personalized, intelligent, and diversified knowledge-based service system platform solution to port supply chain enterprises, helping to realize port supply chain transformation and upgrading and intelligent integrated operations. This paper analyses and summarizes the research status on knowledge service demand and port supply chain knowledge service during the development and operation of the port supply chain and applies big data and artificial intelligence technologies such as knowledge matching, knowledge fusion, and natural language processing. A port supply chain knowledge service model including knowledge acquisition, knowledge organization and knowledge service modules is constructed. The ontology method is used to construct the ontology knowledge base of the port supply chain, and based on this, computational reasoning experiments are performed. The experiments show that ontology technology demonstrates effectiveness and superiority in constructing a knowledge service system model for the port supply chain in terms of knowledge representation and knowledge reasoning.},
journal = {Neural Comput. Appl.},
month = mar,
pages = {1699–1710},
numpages = {12},
keywords = {Port supply chain, Knowledge service, Noumenon, Knowledge fusion}
}

