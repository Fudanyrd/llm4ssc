doi = {10.1504/ijict.2022.126488},
abstract = {The lack of bi-level planning of supply chain leads to the problems of low customer satisfaction and low security of information sharing in the upstream supply chain of enterprises. This paper analyses the status quo of information sharing in upstream supply chain, understands the symmetry of information in upstream supply chain, and clarifies the essence of information sharing in upstream supply chain. The information of upstream supply chain is obtained by embedded technology, and the information parameters of upstream supply chain are determined by Baum-Welch algorithm. The information sharing model of the supply chain is divided into tomography model, and the information sharing model of the upstream supply chain is established by using data warehouse technology. The customer satisfaction of this information sharing model is up to 99.25\%, and the security of enterprise information sharing is about 99\%.},
