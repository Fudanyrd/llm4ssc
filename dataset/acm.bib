@inproceedings{10.1145/3772900.3772969,
author = {Liu, He},
title = {Distributed AI-Enabled Intelligent Control System for Enterprise Procurement and Supply-Chain Management},
year = {2026},
isbn = {9798400720963},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3772900.3772969},
doi = {10.1145/3772900.3772969},
abstract = {In the era of globalization and digital transformation, enterprise procurement and supply-chain operations face unprecedented challenges arising from heterogeneous data sources, multi-agent interactions, and volatile market environments. This paper introduces a distributed AI-enabled control architecture that harmonizes IoT-based sensing, deep-learning forecasting, and reinforcement-learning decision policies to optimize procurement, inventory management, and logistics scheduling. The system employs edge-to-cloud data fusion through hierarchical neural networks, which extract salient features from supplier, warehouse, and transportation sensors. Demand, lead-time, and price fluctuations are forecasted using recurrent and transformer-based deep models. Procurement and inventory decisions are driven by reinforcement-learning agents trained to minimize total costs under uncertainty. A natural-language-processing module automatically parses contract texts and identifies anomalies in purchase orders, triggering risk-mitigation workflows. Finally, a federated multi-agent coordination framework aligns the objectives of suppliers, buyers, and carriers while preserving data privacy. Experimental results at a major manufacturing firm demonstrate a 22\% increase in data-fusion accuracy, a 75\% reduction in inter-departmental coordination delays, and over a 90\% decrease in procurement exceptions, validating the efficacy of the proposed intelligent control system. The architecture also lays a foundation for future extensions in autonomous warehouse robotics and sustainable logistics operations.},
booktitle = {Proceedings of the 2025 International Conference on Information Economy, Data Modeling and Cloud Computing},
pages = {429–437},
numpages = {9},
keywords = {Deep Neural Networks, Distributed Artificial Intelligence, Intelligent Control Systems, IoT Data Fusion, Multi-Agent Coordination, Natural Language Processing, Reinforcement Learning, Supply-Chain Optimization},
location = {
},
series = {ICIDC '25}
}

