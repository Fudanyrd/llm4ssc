@inproceedings{10.1145/3764727.3764774,
author = {Zuo, Jingyang},
title = {Catering supply chain resilience optimization algorithm from the perspective of multi-agent simulation (MAS)},
year = {2025},
isbn = {9798400714955},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3764727.3764774},
doi = {10.1145/3764727.3764774},
abstract = {In response to the problem of insufficient resilience of the catering supply chain during the COVID-19 pandemic, this paper proposes a R-OQL optimization algorithm based on multi-agent simulation (MAS). By integrating the cross-agent collaborative framework of government policies, corporate decisions and consumer behaviors, the resilience of the supply chain in crisis scenarios can be improved. The experiment is based on the simulation of the catering industry data in 2020 in the paper. The results show that: in the peak blockade intensity scenario, the R-OQL algorithm achieves an income recovery rate of 82.4\%, an increase of 22.4\% over the traditional Q-Learning, and a reduction of 18.7\% in cost volatility; the cash flow break threshold is increased from 60.26 billion yuan to 89.13 billion yuan, an increase of 47.9\%. Compared with the static policy model, the unit policy cost efficiency (RI/100 million yuan) of R-OQL is increased by 37.5\%, which verifies the adaptability of the dynamic weight mechanism to complex shocks. When the government subsidy rate is dynamically adjusted to 10.5\% and the enterprise labor elasticity is adjusted to 18\%, the system resilience index (RI) reaches 1.27, an increase of 41.3\% over the baseline scenario. This study provides a quantifiable algorithmic tool for intelligent resilience management of the service industry supply chain, and its cross-agent collaborative idea can be extended to other service fields affected by the crisis.},
booktitle = {Proceedings of the 2025 International Conference on Artificial Intelligence and Digital Finance},
pages = {306–311},
numpages = {6},
keywords = {catering supply chain, dynamic weight, improved q-learning algorithm, master agent simulation (MAS), resilience optimization, system risk resistance},
location = {
},
series = {AIDF '25}
}

@inproceedings{10.1145/3719027.3765094,
author = {So, Johnny and Ferdman, Michael and Nikiforakis, Nick},
title = {What Gets Measured Gets Managed: Mitigating Supply Chain Attacks with a Link Integrity Management System},
year = {2025},
isbn = {9798400715259},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3719027.3765094},
doi = {10.1145/3719027.3765094},
abstract = {The web continues to grow, but dependency-monitoring tools and standards for resource integrity lag behind. Currently, there exists no robust method to verify the integrity of web resources, much less in a generalizable yet performant manner, and supply chains remain one of the most targeted parts of the attack surface of web applications.In this paper, we present the design of LiMS, a transparent system to bootstrap link integrity guarantees in web browsing sessions with minimal overhead. At its core, LiMS uses a set of customizable integrity policies to declare the (un)expected properties of resources, verifies these policies, and enforces them for website visitors. We discuss how basic integrity policies can serve as building blocks for a comprehensive set of integrity policies, while providing guarantees that would be sufficient to defend against recent supply chain attacks detailed by security industry reports. Finally, we evaluate our open-sourced prototype by simulating deployments on a representative sample of 450 domains that are diverse in ranking and category. We find that our proposal offers the ability to bootstrap marked security improvements with an overall overhead of hundreds of milliseconds on initial page loads, and negligible overhead on reloads, regardless of network speeds. In addition, from examining archived data for the sample sites, we find that several of the proposed policy building blocks suit their dependency usage patterns, and would incur minimal administrative overhead.},
booktitle = {Proceedings of the 2025 ACM SIGSAC Conference on Computer and Communications Security},
pages = {3027–3041},
numpages = {15},
keywords = {browser, policies, service worker, web resource integrity},
location = {Taipei, Taiwan},
series = {CCS '25}
}

