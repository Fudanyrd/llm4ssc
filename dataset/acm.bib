author = {He, Hui-Yu and Chen, Bing-Chuan and Wu, Jie-Yi and Liang, Ai-Shi},
title = {Analysis on the Impact of Supply Chain Resilience on Corporate Profitability under A-share Data},
year = {2025},
isbn = {9798400713347},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3757749.3757772},
doi = {10.1145/3757749.3757772},
abstract = {Under the dual background of Sino-US strategic competition and global supply chain reconstruction, the role of supply chain resilience in guaranteeing corporate profitability is becoming more and more prominent. This study adopts the entropy weight method to construct a multidimensional supply chain resilience index, and applies DuPont analysis to measure corporate profitability, and empirically analyzes it based on the data of China's A-share listed companies (2007–2022). In addition, the heterogeneity of this mechanism is explored. It is found that: the nonlinear positive effect of supply chain toughness on profitability is significant, and the marginal effect decreases with the increase of toughness level; the results of heterogeneity analysis show that the supply chain toughness of manufacturing firms promotes profitability 37 times more than that of non-manufacturing firms, with the intensity of the effect in the high-tech manufacturing industry being 6.4 times more than that of the low-tech manufacturing industry. It provides important empirical evidence for enterprises to implement differentiated toughness construction strategy in global supply chain reconstruction.},
booktitle = {Proceedings of the 2025 2nd International Conference on Computer and Multimedia Technology},
pages = {142–148},
numpages = {7},
keywords = {data mining, manufacturing heterogeneity, nonlinear effects, profitability, supply chain resilience},
location = {
},
series = {ICCMT '25}
}

@article{10.4018/JGIM.335125,
