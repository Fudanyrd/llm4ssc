@INPROCEEDINGS{11293868,
author={Lin, Han W. and Stout, William M.S. and Morris, Tyler J.},
booktitle={2025 IEEE International Carnahan Conference on Security Technology (ICCST)}, 
title={Assessing Software Security Maturity via an AI-Augmented Risk-Based Framework}, 
year={2025},
volume={},
number={},
pages={1-6},
abstract={The software security landscape has grown increasingly complex, with software supply chain attacks surging by 431% from 2021 to 2023; 86% of code bases contain at least one open-source vulnerability and 80% of applications harbor known security flaws, exposing critical systems across sectors such as healthcare, finance, and national infrastructure to exploitation. Strengthening software security is essential to protect privacy, stability, and public trust. This paper introduces a novel risk-based software security maturity framework designed to help organizations evaluate and enhance their software security practices, leveraging AI-powered Large Language Models (LLMs). These LLMs stream ingestion of organizational data and assist in generating reports tailored to organizational needs, enhancing the accuracy and relevance of security evaluations. The framework empowers organizations to assess capabilities, vulnerabilities, and risks in critical areas while offering a clear roadmap for continuous improvement. By adopting a threat-informed approach that maps threat actors and vectors to maturity levels, and combining this strategic understanding with AI-driven insights, the framework delivers a nuanced and adaptive solution for improving defense readiness and resilience in the face of evolving cybersecurity challenges.},
keywords={Privacy;Accuracy;Supply chains;Organizations;Software;Stability analysis;Vectors;Security;Software measurement;Computer security;Cybersecurity;Secure Software;Framework;LLM},
doi={10.1109/ICCST63435.2025.11293868},
ISSN={},
month={Oct},}
@INPROCEEDINGS{11430751,
author={Syed, Toqeer Ali and Riyaz Belgaum, Mohammad and Jan, Salman and Khan, Asadullah Abdullah and Alqahtani, Saad Said},
booktitle={2025 International Conference on Computer and Applications (ICCA)}, 
title={Agentic AI for Autonomous Defense in Software Supply Chain Security: Beyond Provenance to Vulnerability Mitigation}, 
year={2025},
volume={},
number={},
pages={1-6},
abstract={Software supply chain attacks increasingly target trusted development and delivery processes, making conventional post-build integrity mechanisms insufficient. Existing frameworks like SLSA, SBOM, and in-toto mainly provide provenance and traceability but cannot actively identify or remove vulnerabilities during production. This paper presents an agentic AI approach for autonomous software supply chain security, combining large language model (LLM) reasoning, reinforcement learning (RL), and multi-agent coordination. The system employs specialized security agents that interact with CI/CD environments, collaborate intelligently to identify and mitigate threats, and document actions for integrity and auditing. RL enables adaptive mitigation strategies balancing security effectiveness and operational overhead, while LLMs provide semantic vulnerability analysis and explainable decisions. The framework is evaluated on simulated pipelines and actual CI/CD integrations, including injection attacks, insecure deserialization, access control violations, and configuration errors. Results show improved detection accuracy, shorter mitigation latency, and reasonable build-time overhead compared to rule-based, provenance-only, and RL-only baselines, demonstrating that agentic AI can enable proactive, self-defending software supply chains.},
keywords={Agentic AI;Access control;Prevention and mitigation;Supply chains;Semantics;Pipelines;Reinforcement learning;Software;Cognition;Security},
doi={10.1109/ICCA66035.2025.11430751},
ISSN={},
month={Dec},}
@INPROCEEDINGS{9936015,
author={Swain, Satyananda and Patra, Manas Ranjan},
booktitle={2022 IEEE International Conference on Blockchain and Distributed Systems Security (ICBDS)}, 
title={A Distributed Agent-Oriented Framework for Blockchain-Enabled Supply Chain Management}, 
year={2022},
volume={},
number={},
pages={1-7},
abstract={Blockchain has emerged as a leading technological innovation because of its indisputable safety and services in a distributed setup. Applications of blockchain are rising covering varied fields such as financial transactions, supply chains, maintenance of land records, etc. Supply chain management is a potential area that can immensely benefit from blockchain technology (BCT) along with smart contracts, making supply chain operations more reliable, safer, and trustworthy for all its stakeholders. However, there are numerous challenges such as scalability, coordination, and safety-related issues which are yet to be resolved. Multi-agent systems (MAS) offer a completely new dimension for scalability, cooperation, and coordination in distributed culture. MAS consists of a collection of automated agents who can perform a specific task intelligently in a distributed environment. In this work, an attempt has been made to develop a framework for implementing a multi-agent system for a large-scale product manufacturing supply chain with blockchain technology wherein the agents communicate with each other to monitor and organize supply chain operations. This framework eliminates many of the weaknesses of supply chain management systems. The overall goal is to enhance the performance of SCM in terms of transparency, traceability, trustworthiness, and resilience by using MAS and BCT.},
keywords={Technological innovation;Supply chain management;Scalability;Supply chains;Software agents;Blockchains;Stakeholders;Blockchain Technology;Multi-Agent System;Smart Contract;Supply Chain Management},
doi={10.1109/ICBDS53701.2022.9936015},
