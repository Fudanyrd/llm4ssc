@INPROCEEDINGS{9885471,
author={Idayakumar, Pritamsunder and Mahadik, Sakshi and Paul, Ishita and Chaure, Suvarna},
booktitle={2022 International Conference on Computing, Communication, Security and Intelligent Systems (IC3SIS)}, 
title={Vaccine Supply Management using Blockchain}, 
year={2022},
volume={},
number={},
pages={1-8},
abstract={In late 2019, we witnessed the apparition of the COVID-19 virus. It first appeared in Wuhan, China and due to people traveling worldwide, it spread globally. The world went into a global lockdown because of its exponential spread and high mortality rates. Social distancing measures, crises in the economy, and healthcare posed many challenges for scientists, researchers, and healthcare workers. To try to combat this situation, multiple vaccines were tried, tested, and created in a very short amount of time. Therefore, a robust yet transparent supply chain system is very crucial in ensuring an efficient vaccination campaign. We propose a blockchain-based vaccination supply chain system to manage the registration, storage and distribution of the vaccines. Blockchain is a decentralized, distributed ledger that records all the transactions happening between the nodes in the network. The data is stored in the ledger in the form of blocks that are linked to each other by hashes, this makes tampering with the data virtually impossible. Blockchain properties will provide a distributed system along with greater privacy, transparency, and authenticity. Smart contracts deployed will help in monitoring and tracking the proper vaccine distribution conditions against the rules and regulations given by the authorities. The tamperproof nature of blockchain would ensure the supply of proper distribution of only authentic vaccines in a timely manner and traceability of the supply chain will help in increasing the people’s trust in the vaccination campaign.},
keywords={COVID-19;Supply chains;Smart contracts;Transportation;Production;Social factors;Vaccines;Blockchain;vaccines;supply chain;smart contracts;decentralized;traceability},
doi={10.1109/IC3SIS54991.2022.9885471},
ISSN={},
month={June},}
@INPROCEEDINGS{11190193,
author={Park, Seongmin and Min, Dugki and Nguyen, Tuan Anh and Choi, Eunmi},
booktitle={2025 International Conference on Metaverse Computing, Networking and Applications (MetaCom)}, 
title={Metaverse Security: LLM-Based Malicious Code Detection Through Token Optimization}, 
year={2025},
volume={},
number={},
pages={316-323},
abstract={Metaverse platforms increasingly offer immersive virtual environments while simultaneously introducing significant vulnerabilities through malicious code, particularly when concealed within software supply chains. To address these security challenges, this study utilizes Large Language Models (LLMs) for the detection of harmful JavaScript code. Specifically, it underscores the pivotal role of optimising input token length in order to enhance both detection accuracy and overall computational efficiency. To examine this optimisation process, we conduct an empirical comparison of several advanced LLMs—namely CodeLLaMA, LLaMA-2/3, Qwen2.5, and EXAONE-3.5—across token ranges from 500 up to 128K. Our findings reveal that the optimal input size varies considerably among these models, indicating that arbitrarily enlarging token counts does not inherently improve performance. Notably, Qwen2.5 achieves an F1 score of 0.9276 at an input size of 5120 tokens, thereby surpassing diverse conventional approaches as well as large-context baselines. This outcome highlights the viability of tailored input lengths as a practical and efficient security measure for metaverse ecosystems. By adhering to an optimal token length strategy, our study not only diminishes computational overhead but also accelerates inference times, a crucial consideration in safeguarding modern metaverse infrastructures. These results confirm that a carefully calibrated approach to token length can strike a balance between precision and resource management, offering an effective mechanism to thwart malicious JavaScript activity. Consequently, this line of inquiry opens the way for LLM-driven security frameworks that combine thorough threat detection with tangible gains in computational performance.},
keywords={Codes;Metaverse;Computational modeling;Large language models;Biological system modeling;Malware;Computational efficiency;Windows;Security;Optimization;Large Language Models (LLMs);Malicious Code Detection;Metaverse Security;Token Length Optimization;Computational Efficiency;Performance Evaluation},
doi={10.1109/MetaCom65502.2025.00057},
ISSN={},
month={Aug},}
@INPROCEEDINGS{10301242,
author={Peng, Xutan and Zhang, Yipeng and Yang, Jingfeng and Stevenson, Mark},
booktitle={2023 IEEE 34th International Symposium on Software Reliability Engineering (ISSRE)}, 
title={On the Vulnerabilities of Text-to-SQL Models}, 
year={2023},
volume={},
number={},
pages={1-12},
abstract={Although it has been demonstrated that Natural Language Processing (NLP) algorithms are vulnerable to deliberate attacks, the question of whether such weaknesses can lead to software security threats is under-explored. To bridge this gap, we conducted vulnerability tests on Text-to-SQL systems that are commonly used to create natural language interfaces to databases. We showed that the Text-to-SQL modules within six commercial applications can be manipulated to produce malicious code, potentially leading to data breaches and Denial of Service attacks. 1 This is the first demonstration that NLP models can be exploited as attack vectors in the wild. In addition, experiments using four open-source language models verified that straightforward backdoor attacks on Text-to-SQL systems achieve a 100% success rate without affecting their performance. The aim of this work is to draw the community’s attention to potential software security issues associated with NLP algorithms and encourage exploration of methods to mitigate against them.},
keywords={Databases;Software algorithms;Data breach;Natural language processing;Malware;Data models;Software reliability;Natural Language Processing;Code Generation;Database;SQL Injection;Reliability Threats},
doi={10.1109/ISSRE59848.2023.00047},
ISSN={2332-6549},
month={Oct},}
@INPROCEEDINGS{11360395,
author={Cai, Zhenqi and Cai, Yongxin and Leng, Tao and Zhou, Huacong and Xie, Xiaobin and Sun, Yifei and Chai, Yuhan and Qiu, Jing},
booktitle={2025 IEEE 10th International Conference on Data Science in Cyberspace (DSC)}, 
title={MalGuard: Malicious Package Detection Based on Dual Validation of Rule Scanning and Large Language Model}, 
year={2025},
volume={},
number={},
pages={287-294},
abstract={The open source software (OSS) supply chain has become a key target for attackers, and one of the common ways of attack is to execute attacks through malicious packets in the package registry. In the face of this serious security challenge, although several detection tools have been proposed, they have limitations in identifying malicious behavior. While current malware package detection techniques can help the manual review process to be more efficient by predicting possible malware packages, such methods are often accompanied by a high misclassification rate. Therefore, improvements are focused on employing more advanced automated strategies to enhance detection accuracy and reduce misclassification. In this paper, we propose a malware package detection method called MalGuard based on the dual validation of rule scanning and LLM, which aims to identify malware packages in NPM and PyPI, and to improve the security protection of OSS supply chain. The method quickly screens suspicious code features by integrating a static scanning tool with YARA and Semgrep rules, and effectively identifies obfuscated attacks that are difficult to detect with traditional rules by combining LLM's deep semantic reasoning on the code context. For missed samples, the system automatically extracts behavioral features to generate optimized detection rules, and dynamically updates the rule base to form a closed loop of “Detection-Verification-Evolution”. The method not only considers the sensitive operation functions in the malicious code, but also uses the LLM to identify static features, Abstract Syntax Tree (AST), and sensitive API call sequences including third-party libraries. Evaluation results show that MalGuard achieves $94.3 \% / 84.7 \%$ F1 scores in detecting new and unknown malicious packets, respectively, compared to the current approach.},
keywords={Technological innovation;Codes;Trees (botanical);Supply chains;Semantics;Static analysis;Syntactics;Feature extraction;Malware;Security;Software Supply Chain;Static Analysis;Malware;LLM;NPM;PyPI},
doi={10.1109/DSC67331.2025.00044},
ISSN={},
month={Aug},}
